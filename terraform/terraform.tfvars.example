## Copy to terraform.tfvars and fill values.
## Note: bucket_name must be globally unique.

project_id  = "your-gcp-project-id"
region      = "us-central1"
zone        = "us-central1-a"

bucket_name = "your-unique-bucket-name"

dataset_id  = "chat_streaming"

topic_name         = "topic-conversation"
subscription_name  = "submessages"

table_conversations_name = "conversations"
table_orders_name        = "orders"

environment           = "dev"
owner_label           = "data-eng"
enable_project_apis   = true
pipeline_service_account_id = "streaming-pipeline-sa"

bucket_temp_cleanup_age_days          = 14
bucket_soft_delete_retention_seconds  = 604800
pubsub_ack_deadline_seconds           = 20
pubsub_retry_minimum_backoff          = "10s"
pubsub_retry_maximum_backoff          = "600s"
pubsub_max_delivery_attempts          = 10

create_dead_letter_subscription          = true
dead_letter_subscription_name            = "submessages-dlq-audit"
dead_letter_sub_ack_deadline_seconds     = 60
dead_letter_sub_message_retention_duration = "604800s"

